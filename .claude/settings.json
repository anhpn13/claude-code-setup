{
  "_readme": "File này an toàn để commit — KHÔNG chứa ANTHROPIC_AUTH_TOKEN. User mới sao chép repo, đặt API key ở .env (gitignored) theo hướng dẫn docs/0-init/01-claude-code-minimax.md § A.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-secret-scan.py\""
          }
        ]
      }
    ]
  },
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.minimax.io/anthropic",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1000000",
    "ANTHROPIC_MODEL": "MiniMax-M3[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "MiniMax-M3[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "MiniMax-M3[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "MiniMax-M3[1m]"
  },
  "enabledMcpServers": [
    "firecrawl"
  ]
}