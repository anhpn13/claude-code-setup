# .env.example — template for local secrets.
# Copy to .env and fill in real values. .env is gitignored.
# mise auto-loads .env via the `_.file` entry in mise.toml.
# Claude Code / MCP servers running in this project inherit these values.

# === Firecrawl MCP ===
# API key for https://firecrawl.dev. Required by the firecrawl-mcp server
# referenced in .mcp.json. Get one at https://firecrawl.dev/account.
FIRECRAWL_API_KEY=

# === GitHub ===
# Personal Access Token with `repo` scope. Used by `gh auth login` and
# by git over HTTPS when pushing to github.com from this repo.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# === Demo server (Petstore + SSH-qua-wstunnel) ===
# Mỗi học viên đặt 1 giá trị riêng. Server demo coi như opaque và
# dùng nó để cô lập log (`student=<id>` xuất hiện trong từng dòng log).
# Khai báo ở đây để cả 2 task `petstore-create` và `ssh-logs` tự động
# nhặt được. Ví dụ:
#   PETSTORE_STUDENT_ID=nguyen-anh
PETSTORE_STUDENT_ID=

# Tùy chọn — bỏ comment để ghi đè URL public mặc định (chỉ dùng khi
# server demo đổi địa chỉ).
# PETSTORE_BASE_URL=https://petstore-ai-course-demo.sandbox.vnpt-technology.vn:9443/api/v3
# PETSTORE_WSS_URL=wss://passthrough-ai-course-demo-ssh.sandbox.vnpt-technology.vn:9443

# === Anthropic (Claude Code API — dùng qua MiniMax provider) ===
# `mise exec -- claude` (xem docs/2-core/00-CLAUDE.md) auto-load .env này
# và nhặt được 2 biến dưới để gọi model. Nếu không có, Claude Code tự động
# rơi về Anthropic public API (có thể tính phí khác).
#
# Lấy API key:
#   - MiniMax provider: https://api.minimax.io/anthropic (cần tài khoản nội bộ MiniMax)
#   - Anthropic trực tiếp: https://console.anthropic.com/settings/keys
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000
ANTHROPIC_MODEL=MiniMax-M3[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M3[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M3[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M3[1m]