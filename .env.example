# .env.example — template for local secrets.
# Copy to .env and fill in real values. .env is gitignored.
# mise auto-loads .env via the `_.file` entry in mise.toml.
# Claude Code / MCP servers running in this project inherit these values.

# === Firecrawl MCP ===
# API key for https://firecrawl.dev. Required by the firecrawl-mcp server
# referenced in .mcp.json. Get one at https://firecrawl.dev/account.
FIRECRAWL_API_KEY=

# === GitHub ===
# Personal Access Token with `repo` scope. Used by `gh auth login` and
# by git over HTTPS when pushing to github.com from this repo.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=